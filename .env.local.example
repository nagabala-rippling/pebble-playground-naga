# Confluence Sync Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git (it's in .gitignore)

# Your Confluence base URL
CONFLUENCE_BASE_URL=https://rippling.atlassian.net

# Your Rippling email address
CONFLUENCE_USER_EMAIL=your-email@rippling.com

# Create an API token at: https://id.atlassian.com/manage/api-tokens
CONFLUENCE_API_TOKEN=paste-your-token-here

# Optional: Override the space key (defaults to value in config file)
# CONFLUENCE_SPACE_KEY=PEBBLE
